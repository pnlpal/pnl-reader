[
  {
    "match": "https://www.wattpad.com/\\d+.*",
    "articleSelector": ".page pre",
    "excludes": [".component-wrapper"],
    "navigation": {
      "next": "#story-part-navigation a"
    }
  },
  {
    "match": "https://novelfull.com/[^/]+/[^/]+\\.html$",
    "articleSelector": "#chapter-content",
    "titleSelector": "a.chapter-title",
    "excludes": ["div", "h3"]
  }
]
